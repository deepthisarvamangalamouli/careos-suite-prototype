# --- Frontend (Vite) — used in the browser, safe to expose ---
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=xxxxx

# --- Backend (Vercel serverless functions in /api) — server-side only ---

# Supabase service role key (Project Settings → API). Needed by the Stripe
# webhook to write billing status without going through RLS.
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=xxxxx

# Stripe (dashboard.stripe.com, test mode keys are fine for the prototype)
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PRICE_STARTER=price_xxxxx
STRIPE_PRICE_GROWTH=price_xxxxx
STRIPE_PRICE_AGENCY=price_xxxxx

# Groq (console.groq.com)
GROQ_API_KEY=gsk_xxxxx

# Your deployed site URL, used for Stripe redirect/return URLs.
# For local dev this can stay unset — it falls back to the request host.
PUBLIC_SITE_URL=https://your-app.vercel.app
